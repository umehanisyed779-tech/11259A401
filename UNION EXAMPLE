#include <stdio.h>

union Data {
    int i;
    float f;
    char str[20];
};

int main() {
    union Data d;

    d.i = 10;
    printf("Integer: %d\n", d.i);

    d.f = 5.5;
    printf("Float: %.2f\n", d.f);

    printf("Integer after float assign: %d\n", d.i);

    return 0;
}

OUTPUT:
Integer: 10
Float: 5.50
Integer after float assign: (garbage value)

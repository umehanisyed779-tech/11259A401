#include <stdio.h>

int main() {
    int A[2][2] = {{5, 6}, {7, 8}};
    int B[2][2] = {{1, 2}, {3, 4}};
    int C[2][2];
    int i, j;

    for(i = 0; i < 2; i++) {
        for(j = 0; j < 2; j++) {
            C[i][j] = A[i][j] - B[i][j];
        }
    }

    printf("Subtraction Result:\n");
    for(i = 0; i < 2; i++) {
        for(j = 0; j < 2; j++) {
            printf("%d ", C[i][j]);
        }
        printf("\n");
    }

    return 0;
}
OUTPUT:
Subtraction Result:
4 4
4 4
